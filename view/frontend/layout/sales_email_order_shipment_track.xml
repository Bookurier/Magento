<?xml version="1.0"?>
<!--
/**
 * Override shipment email tracking block for Bookurier links and summary.
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceBlock name="sales.order.email.shipment.track" template="Bookurier_Shipping::email/shipment/track.phtml">
            <arguments>
                <argument name="tracking_url" xsi:type="object">Bookurier\Shipping\Block\DataProviders\Email\Shipment\TrackingUrl</argument>
                <argument name="bookurier_summary" xsi:type="object">Bookurier\Shipping\ViewModel\Email\Shipment\BookurierSummary</argument>
            </arguments>
        </referenceBlock>
    </body>
</page>
