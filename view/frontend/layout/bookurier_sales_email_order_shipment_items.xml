<?xml version="1.0"?>
<!--
/**
 * Email Shipment Items List (Bookurier all shipments).
 */
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd"
      label="Bookurier Email Shipment Items List"
      design_abstraction="custom">
    <update handle="sales_email_order_shipment_renderers"/>
    <body>
        <block class="Magento\Sales\Block\Order\Email\Shipment\Items"
               name="items"
               template="Bookurier_Shipping::email/shipment/items_all.phtml">
            <block class="Magento\Framework\View\Element\RendererList"
                   name="sales.email.order.shipment.renderers"
                   as="renderer.list"/>
        </block>
        <block class="Magento\Framework\View\Element\Template"
               name="additional.product.info"
               template="Magento_Theme::template.phtml"/>
    </body>
</page>
