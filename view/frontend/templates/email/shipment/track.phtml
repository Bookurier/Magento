<?php
/**
 * Bookurier-aware shipment tracking block for shipment emails.
 */
?>
<?php /* @var \Magento\Framework\View\Element\Template $block */ ?>
<?php $_shipment = $block->getShipment() ?>
<?php $_order = $block->getOrder() ?>
<?php if ($_shipment && $_order) : ?>
    <?php $isBookurierOrder = strpos((string)$_order->getShippingMethod(), 'bookurier_') === 0; ?>
    <?php $trackCollection = $_shipment->getTracksCollection() ?>
    <?php if (!$isBookurierOrder && $trackCollection) : ?>
        <br />
        <table class="shipment-track">
            <thead>
            <tr>
                <th><?= $block->escapeHtml(__('Shipped By')) ?></th>
                <th><?= $block->escapeHtml(__('Tracking Number')) ?></th>
            </tr>
            </thead>
            <tbody>
            <?php foreach ($trackCollection as $_item) : ?>
                <tr>
                    <td><?= $block->escapeHtml($_item->getTitle()) ?>:</td>
                    <td>
                        <a href="<?= $block->escapeUrl($block->getTrackingUrl()->getUrl($_item)) ?>" target="_blank">
                            <?= $block->escapeHtml($_item->getNumber()) ?>
                        </a>
                    </td>
                </tr>
            <?php endforeach ?>
            </tbody>
        </table>
    <?php endif; ?>

    <?php if ($isBookurierOrder) : ?>
        <?php $summaryProvider = $block->getData('bookurier_summary'); ?>
        <?php $summaryRows = is_object($summaryProvider) ? $summaryProvider->getRowsByOrderId((int)$_order->getEntityId()) : []; ?>

        <br />
        <table class="shipment-track">
            <thead>
            <tr>
                <th><?= $block->escapeHtml(__('Shipment')) ?></th>
                <th><?= $block->escapeHtml(__('Bookurier AWB Code(s)')) ?></th>
            </tr>
            </thead>
            <tbody>
            <?php foreach ($summaryRows as $row) : ?>
                <tr>
                    <td>
                        <?= $block->escapeHtml(__('Shipment %1 (ID: %2)', $row['shipment_label'], (int)$row['shipment_id'])) ?>
                    </td>
                    <td>
                        <?php if (!empty($row['awb_codes'])) : ?>
                            <?php foreach ($row['awb_codes'] as $awbCode) : ?>
                                <div>
                                    <a href="<?= $block->escapeUrl('https://t.bookurier.ro/?awb=' . rawurlencode((string)$awbCode)) ?>" target="_blank">
                                        <?= $block->escapeHtml($awbCode) ?>
                                    </a>
                                </div>
                            <?php endforeach; ?>
                        <?php else : ?>
                            <?= $block->escapeHtml(__('No AWB yet')) ?>
                        <?php endif; ?>
                    </td>
                </tr>
            <?php endforeach; ?>
            </tbody>
        </table>
    <?php endif; ?>
<?php endif; ?>
