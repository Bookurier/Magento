<?xml version="1.0"?>
<!--
/**
 * Bookurier Shipping system configuration.
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <section id="carriers" type="text" sortOrder="320" showInDefault="1" showInWebsite="1" showInStore="1">
            <group id="bookurier" translate="label" type="text" sortOrder="200" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Bookurier</label>
                <field id="active" translate="label" type="select" sortOrder="1" showInDefault="1" showInWebsite="1" canRestore="1">
                    <label>Enabled</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="title" translate="label" type="text" sortOrder="2" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Title</label>
                </field>
                <field id="name" translate="label" type="text" sortOrder="3" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Method Name</label>
                </field>
                <field id="price" translate="label" type="text" sortOrder="4" showInDefault="1" showInWebsite="1" canRestore="1">
                    <label>Price</label>
                    <validate>validate-number validate-zero-or-greater</validate>
                </field>
                <field id="tracking_url" translate="label" type="text" sortOrder="5" showInDefault="1" showInWebsite="1" canRestore="1">
                    <label>Tracking Url</label>
                    <validate>validate-url</validate>
                </field>
                <field id="handling_type" translate="label" type="select" sortOrder="6" showInDefault="1" showInWebsite="1" canRestore="1">
                    <label>Calculate Handling Fee</label>
                    <source_model>Magento\Shipping\Model\Source\HandlingType</source_model>
                </field>
                <field id="handling_fee" translate="label" type="text" sortOrder="7" showInDefault="1" showInWebsite="1" canRestore="1">
                    <label>Handling Fee</label>
                    <validate>validate-number validate-zero-or-greater</validate>
                </field>
                <field id="available_in_checkout" translate="label" type="select" sortOrder="8" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Available in Checkout</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="sallowspecific" translate="label" type="select" sortOrder="90" showInDefault="1" showInWebsite="1" canRestore="1">
                    <label>Ship to Applicable Countries</label>
                    <frontend_class>shipping-applicable-country</frontend_class>
                    <source_model>Magento\Shipping\Model\Config\Source\Allspecificcountries</source_model>
                </field>
                <field id="specificcountry" translate="label" type="multiselect" sortOrder="91" showInDefault="1" showInWebsite="1">
                    <label>Ship to Specific Countries</label>
                    <source_model>Magento\Directory\Model\Config\Source\Country</source_model>
                    <can_be_empty>1</can_be_empty>
                </field>
                <field id="showmethod" translate="label" type="select" sortOrder="92" showInDefault="1" showInWebsite="1">
                    <label>Show Method if Not Applicable</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <frontend_class>shipping-skip-hide</frontend_class>
                </field>
                <field id="specificerrmsg" translate="label" type="textarea" sortOrder="93" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Displayed Error Message</label>
                </field>
                <field id="sort_order" translate="label" type="text" sortOrder="100" showInDefault="1" showInWebsite="1">
                    <label>Sort Order</label>
                    <validate>validate-number validate-zero-or-greater</validate>
                </field>

                <field id="api_user" translate="label" type="text" sortOrder="200" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>API User</label>
                </field>
                <field id="api_pwd" translate="label" type="obscure" sortOrder="201" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>API Password</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
                <field id="api_key" translate="label" type="text" sortOrder="202" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>API Key</label>
                </field>
                <field id="api_endpoint" translate="label" type="text" sortOrder="203" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>API Endpoint</label>
                    <comment>Base endpoint without path, e.g. https://portal.bookurier.ro</comment>
                    <validate>validate-url</validate>
                </field>
                <field id="pickup_point" translate="label" type="text" sortOrder="204" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Default Pickup Point</label>
                </field>
                <field id="service" translate="label" type="select" sortOrder="205" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Default Service Code</label>
                    <source_model>Bookurier\Shipping\Model\Config\Source\Service</source_model>
                </field>
                <field id="print_awb_mode" translate="label" type="select" sortOrder="206" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Print AWB Mode</label>
                    <source_model>Bookurier\Shipping\Model\Config\Source\PrintAwbMode</source_model>
                </field>
                <field id="print_awb_format" translate="label" type="select" sortOrder="207" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Print AWB Format</label>
                    <source_model>Bookurier\Shipping\Model\Config\Source\PrintAwbFormat</source_model>
                </field>
                <field id="fulfillment_api_url" translate="label" type="text" sortOrder="208" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Fulfillments API URL</label>
                    <comment>Base endpoint without path, used for /api/v3/add_orders.php</comment>
                    <validate>validate-url</validate>
                </field>
                <field id="fulfillment_api_user" translate="label" type="text" sortOrder="209" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Fulfillment API User</label>
                </field>
                <field id="fulfillment_api_pwd" translate="label" type="obscure" sortOrder="210" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Fulfillment API Password</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                </field>
                <field id="fulfillment_packtype" translate="label" type="text" sortOrder="211" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Fulfillment Packtype</label>
                    <validate>validate-digits</validate>
                </field>
                <field id="fulfillment_courier_override" translate="label" type="text" sortOrder="212" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Fulfillment Courier Override</label>
                    <comment>Leave empty to use the order shipping description.</comment>
                </field>
                <field id="default_packs" translate="label" type="text" sortOrder="213" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Default Packs</label>
                    <validate>validate-number validate-zero-or-greater</validate>
                </field>
                <field id="default_weight" translate="label" type="text" sortOrder="214" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Default Weight (kg)</label>
                    <validate>validate-number validate-zero-or-greater</validate>
                </field>
                <field id="api_mock" translate="label" type="select" sortOrder="215" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Mock API Response</label>
                    <comment>Return a simulated success response without calling Bookurier.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="enable_bulk_print_button" translate="label" type="select" sortOrder="216" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Enable Order Grid Print Button</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
                <field id="notify_customer_on_awb_create" translate="label" type="select" sortOrder="217" showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Notify Customer on AWB Creation</label>
                    <comment>Send Magento shipment email when a Bookurier AWB is attached to a shipment.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
        </section>
    </system>
</config>
