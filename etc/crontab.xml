<?xml version="1.0"?>
<!--
/**
 * Cron jobs for Bookurier module.
 */
-->
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="bookurier_awb_queue_process"
             instance="Bookurier\Shipping\Model\Cron\ProcessAwbQueue"
             method="execute">
            <schedule>*/5 * * * *</schedule>
        </job>
    </group>
</config>
